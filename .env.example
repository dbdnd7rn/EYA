# =========================
# Expo (Mobile) - PUBLIC
# =========================
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_NEW_APP_SCHEMA=public
EXPO_PUBLIC_WEB_BASE_URL=https://eya.vercel.app

# Leave empty for normal Expo Go/APK builds unless you are testing a specific redirect URL.
# For production APK, Supabase Auth Redirect URLs must include:
# eya://auth/callback
# For web, Supabase Auth Redirect URLs must include:
# https://eya.vercel.app/auth/callback
# For Expo Go, run the app, tap Google auth, check the console for:
# [google-auth] redirectUri
# Then copy that exact URL into Supabase Auth Redirect URLs.
EXPO_PUBLIC_AUTH_REDIRECT_URL=

EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=YOUR_CLOUDINARY_UPLOAD_PRESET
EXPO_PUBLIC_CLOUDINARY_ASSET_FOLDER=pa-level-supabase/listings

EXPO_PUBLIC_PAYCHANGU_BACKEND=https://paychangu-backend.onrender.com
EXPO_PUBLIC_PAYCHANGU_PUBLIC_KEY=YOUR_PAYCHANGU_PUBLIC_KEY
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_DEV_AUTH_MODE=false

# =========================
# Next.js (Web) - PUBLIC
# =========================
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=YOUR_CLOUDINARY_UPLOAD_PRESET
NEXT_PUBLIC_CLOUDINARY_ASSET_FOLDER=pa-level-supabase/listings

NEXT_PUBLIC_PAYCHANGU_BACKEND=https://paychangu-backend.onrender.com
NEXT_PUBLIC_PAYCHANGU_PUBLIC_KEY=YOUR_PAYCHANGU_PUBLIC_KEY

# =========================
# SERVER ONLY (do NOT use in Expo app)
# =========================
SUPABASE_SERVICE_ROLE_KEY=REPLACE_THIS_ROTATED_VALUE
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_THIS_ROTATED_VALUE
CLOUDINARY_API_SECRET=REPLACE_THIS_ROTATED_VALUE

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=REPLACE_THIS_ROTATED_VALUE
SMTP_FROM="Pa-Level <you@example.com>"
