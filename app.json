{
  "expo": {
    "name": "EYA",
    "slug": "eya",
    "scheme": "eya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "EYA needs microphone access for in-app enquiry calls.",
        "NSCameraUsageDescription": "EYA uses camera permission for in-app call compatibility.",
        "NSLocationWhenInUseUsageDescription": "EYA uses your location to place your food provider, property, or delivery pin accurately."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "POST_NOTIFICATIONS",
        "RECORD_AUDIO",
        "CAMERA",
        "MODIFY_AUDIO_SETTINGS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.vac.eya",
      "versionCode": 5
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-camera",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "EYA uses your location to place your food provider, property, or delivery pin accurately."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b34d4328-7e80-46b8-a6b4-1e47ecb883d8"
      }
    }
  }
}
