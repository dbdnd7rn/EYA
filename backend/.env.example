PORT=4000

# PayChangu backend credentials. Keep these only on the backend host.
PAYCHANGU_SECRET_KEY=sec-live-replace-me
PAYCHANGU_PUBLIC_KEY=pk-live-replace-me
PAYCHANGU_WEBHOOK_SECRET=replace-me
PAYCHANGU_CALLBACK_URL=
PAYCHANGU_RETURN_URL=

EXPO_PUSH_ACCESS_TOKEN=
PUBLIC_BASE_URL=http://localhost:4000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_NEW_APP_SCHEMA=public

# Backward-compatible aliases for PayChangu redirect targets. Prefer
# PAYCHANGU_CALLBACK_URL and PAYCHANGU_RETURN_URL for new deployments.
CHECKOUT_SUCCESS_URL=
CHECKOUT_CANCEL_URL=

# Optional. If set, success/cancel pages will also offer a deep-link back to the app.
APP_SCHEME=pamaketi
